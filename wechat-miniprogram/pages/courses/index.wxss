.core-row {
  display: flex;
  gap: 16rpx;
  width: 100%;
  padding: 20rpx;
  margin-bottom: 12rpx;
  color: #526060;
  text-align: left;
  background: #fbfaf6;
  border: 1rpx solid #dfe5df;
  border-radius: 12rpx;
}

.core-row.done {
  color: #5c8f73;
  background: #e7f1e9;
}

.core-title {
  display: block;
  color: #17385b;
  font-size: 27rpx;
  font-weight: 800;
}

.core-body {
  display: block;
  margin-top: 6rpx;
  color: #526060;
  font-size: 24rpx;
  line-height: 1.45;
}

.course-tabs {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.course-tab {
  width: calc(50% - 7rpx);
  min-height: 112rpx;
  padding: 18rpx;
  text-align: left;
  background: #fbfaf6;
  border: 1rpx solid #dfe5df;
  border-radius: 12rpx;
}

.course-tab text {
  display: block;
  color: #526060;
  font-size: 23rpx;
}

.course-tab text + text {
  margin-top: 8rpx;
  color: #17385b;
  font-size: 27rpx;
  font-weight: 800;
}

.course-tab.active {
  background: #e8eef4;
  border-color: #c7d5e4;
}

.course-title {
  display: block;
  margin-bottom: 14rpx;
  color: #17385b;
  font-size: 36rpx;
  font-weight: 800;
  line-height: 1.3;
}

.outcome-box {
  display: block;
  margin-top: 18rpx;
  padding: 18rpx;
  color: #5c8f73;
  font-size: 25rpx;
  font-weight: 700;
  line-height: 1.55;
  background: #e7f1e9;
  border: 1rpx solid #cfe4d4;
  border-radius: 12rpx;
}

.detail-title {
  display: block;
  margin: 24rpx 0 10rpx;
  color: #17385b;
  font-size: 28rpx;
  font-weight: 800;
}

.list-line {
  display: block;
  color: #526060;
  font-size: 26rpx;
  line-height: 1.6;
}

.lesson-card {
  display: flex;
  gap: 18rpx;
  width: 100%;
  padding: 18rpx;
  margin-bottom: 12rpx;
  background: #fbfaf6;
  border: 1rpx solid #dfe5df;
  border-radius: 12rpx;
  text-align: left;
}

.lesson-card::after {
  border: 0;
}

.lesson-card.active {
  background: #e8eef4;
  border-color: #c7d5e4;
}

.lesson-num {
  flex: 0 0 auto;
  color: #b56d3f;
  font-size: 24rpx;
  font-weight: 800;
}

.lesson-title {
  display: block;
  color: #17385b;
  font-size: 27rpx;
  font-weight: 800;
}

.lesson-body {
  display: block;
  margin-top: 8rpx;
  color: #526060;
  font-size: 24rpx;
  line-height: 1.55;
}

.lesson-detail-card {
  padding: 22rpx;
  margin: 18rpx 0 8rpx;
  background: #ffffff;
  border: 1rpx solid #dfe5df;
  border-radius: 14rpx;
}

.lesson-detail-head {
  display: flex;
  gap: 18rpx;
  padding-bottom: 18rpx;
  margin-bottom: 18rpx;
  border-bottom: 1rpx solid #dfe5df;
}

.lesson-detail-head > text {
  flex: 0 0 auto;
  color: #b56d3f;
  font-size: 24rpx;
  font-weight: 800;
}

.lesson-detail-title {
  display: block;
  color: #17385b;
  font-size: 32rpx;
  font-weight: 800;
}

.lesson-detail-body {
  display: block;
  margin-top: 8rpx;
  color: #526060;
  font-size: 25rpx;
  line-height: 1.55;
}

.detail-subtitle {
  display: block;
  margin-top: 18rpx;
  color: #17385b;
  font-size: 27rpx;
  font-weight: 800;
}

.paragraph,
.step-line {
  display: block;
  margin-top: 10rpx;
  color: #526060;
  font-size: 25rpx;
  line-height: 1.65;
}

.step-line {
  padding: 14rpx;
  background: #fbfaf6;
  border: 1rpx solid #dfe5df;
  border-radius: 10rpx;
}

.assignment-box {
  display: grid;
  gap: 8rpx;
  margin-top: 18rpx;
  padding: 18rpx;
  color: #17385b;
  background: #e7f1e9;
  border: 1rpx solid #cfe4d4;
  border-radius: 12rpx;
}

.assignment-box text:first-child {
  color: #5c8f73;
  font-size: 24rpx;
  font-weight: 800;
}

.assignment-box text:last-child {
  font-size: 26rpx;
  font-weight: 800;
  line-height: 1.5;
}

.book-card {
  padding: 18rpx;
  margin-bottom: 12rpx;
  background: #fbfaf6;
  border: 1rpx solid #dfe5df;
  border-radius: 12rpx;
}

.book-course-card {
  padding: 18rpx;
  margin-bottom: 12rpx;
  background: #e8eef4;
  border: 1rpx solid #c7d5e4;
  border-radius: 12rpx;
}

.book-source {
  display: block;
  color: #b56d3f;
  font-size: 23rpx;
  font-weight: 800;
}

.book-title {
  display: block;
  color: #17385b;
  font-size: 27rpx;
  font-weight: 800;
}

.book-body {
  display: block;
  margin-top: 6rpx;
  color: #526060;
  font-size: 24rpx;
}

.audio-btn {
  margin-top: 22rpx;
}
