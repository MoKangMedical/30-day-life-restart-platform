.core-row {
  display: flex;
  gap: 16rpx;
  width: 100%;
  padding: 20rpx;
  margin-bottom: 12rpx;
  color: #526060;
  text-align: left;
  background: #fbfaf6;
  border: 1rpx solid #dfe5df;
  border-radius: 12rpx;
}

.core-row.done {
  color: #5c8f73;
  background: #e7f1e9;
}

.core-title {
  display: block;
  color: #17385b;
  font-size: 27rpx;
  font-weight: 800;
}

.core-body {
  display: block;
  margin-top: 6rpx;
  color: #526060;
  font-size: 24rpx;
  line-height: 1.45;
}

.course-tabs {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.course-tab {
  width: calc(50% - 7rpx);
  min-height: 112rpx;
  padding: 18rpx;
  text-align: left;
  background: #fbfaf6;
  border: 1rpx solid #dfe5df;
  border-radius: 12rpx;
}

.course-tab text {
  display: block;
  color: #526060;
  font-size: 23rpx;
}

.course-tab text + text {
  margin-top: 8rpx;
  color: #17385b;
  font-size: 27rpx;
  font-weight: 800;
}

.course-tab.active {
  background: #e8eef4;
  border-color: #c7d5e4;
}

.course-title {
  display: block;
  margin-bottom: 14rpx;
  color: #17385b;
  font-size: 36rpx;
  font-weight: 800;
  line-height: 1.3;
}

.outcome-box {
  display: block;
  margin-top: 18rpx;
  padding: 18rpx;
  color: #5c8f73;
  font-size: 25rpx;
  font-weight: 700;
  line-height: 1.55;
  background: #e7f1e9;
  border: 1rpx solid #cfe4d4;
  border-radius: 12rpx;
}

.detail-title {
  display: block;
  margin: 24rpx 0 10rpx;
  color: #17385b;
  font-size: 28rpx;
  font-weight: 800;
}

.list-line {
  display: block;
  color: #526060;
  font-size: 26rpx;
  line-height: 1.6;
}

.lesson-card {
  display: flex;
  gap: 18rpx;
  padding: 18rpx;
  margin-bottom: 12rpx;
  background: #fbfaf6;
  border: 1rpx solid #dfe5df;
  border-radius: 12rpx;
}

.lesson-num {
  flex: 0 0 auto;
  color: #b56d3f;
  font-size: 24rpx;
  font-weight: 800;
}

.lesson-title {
  display: block;
  color: #17385b;
  font-size: 27rpx;
  font-weight: 800;
}

.lesson-body {
  display: block;
  margin-top: 8rpx;
  color: #526060;
  font-size: 24rpx;
  line-height: 1.55;
}

.book-card {
  padding: 18rpx;
  margin-bottom: 12rpx;
  background: #fbfaf6;
  border: 1rpx solid #dfe5df;
  border-radius: 12rpx;
}

.book-course-card {
  padding: 18rpx;
  margin-bottom: 12rpx;
  background: #e8eef4;
  border: 1rpx solid #c7d5e4;
  border-radius: 12rpx;
}

.book-source {
  display: block;
  color: #b56d3f;
  font-size: 23rpx;
  font-weight: 800;
}

.book-title {
  display: block;
  color: #17385b;
  font-size: 27rpx;
  font-weight: 800;
}

.book-body {
  display: block;
  margin-top: 6rpx;
  color: #526060;
  font-size: 24rpx;
}

.audio-btn {
  margin-top: 22rpx;
}
