.score-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 22rpx;
}

.score-card {
  width: calc(50% - 8rpx);
  padding: 22rpx;
  background: #ffffff;
  border: 1rpx solid #e4e9e4;
  border-radius: 16rpx;
}

.score-card text:first-child {
  display: block;
  color: #879190;
  font-size: 23rpx;
}

.score-card text:last-child {
  display: block;
  margin-top: 8rpx;
  color: #17324f;
  font-size: 42rpx;
  font-weight: 800;
}

.action-btn {
  margin-bottom: 14rpx;
}

.field-label {
  display: block;
  margin: 20rpx 0 10rpx;
  color: #17324f;
  font-size: 26rpx;
  font-weight: 800;
}

.input {
  width: 100%;
  min-height: 78rpx;
  padding: 0 20rpx;
  color: #172526;
  background: #f6f8f6;
  border: 1rpx solid #e4e9e4;
  border-radius: 12rpx;
  font-size: 26rpx;
}

.copy-btn {
  min-width: 110rpx;
  min-height: 58rpx;
  color: #17324f;
  background: #eef3f7;
  border-radius: 10rpx;
  font-size: 24rpx;
  font-weight: 800;
}

.generated {
  min-height: 410rpx;
}
