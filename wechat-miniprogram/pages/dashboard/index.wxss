.metrics {
  display: flex;
  gap: 16rpx;
  margin-top: 22rpx;
}

.setup-panel {
  margin-top: 18rpx;
}

.engagement-panel {
  margin-top: 22rpx;
}

.engagement-hero {
  display: flex;
  gap: 18rpx;
  padding: 24rpx;
  background: #e8eef4;
  border: 1rpx solid rgba(23, 56, 91, 0.16);
  border-radius: 16rpx;
}

.engagement-copy {
  flex: 1;
  min-width: 0;
}

.engagement-system {
  display: block;
  color: #5c8f73;
  font-size: 24rpx;
  font-weight: 800;
}

.engagement-title {
  display: block;
  margin-top: 12rpx;
  color: #17385b;
  font-size: 40rpx;
  font-weight: 800;
  line-height: 1.22;
}

.engagement-body {
  display: block;
  margin-top: 12rpx;
  color: #526060;
  font-size: 25rpx;
  line-height: 1.6;
}

.engagement-ring {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 170rpx;
  min-height: 170rpx;
  padding: 16rpx;
  background: #ffffff;
  border: 1rpx solid rgba(23, 56, 91, 0.18);
  border-radius: 14rpx;
}

.engagement-percent {
  color: #17385b;
  font-size: 46rpx;
  font-weight: 800;
  line-height: 1;
}

.engagement-label {
  margin-top: 12rpx;
  color: #7a8584;
  font-size: 22rpx;
}

.ritual-grid {
  display: flex;
  gap: 14rpx;
  margin-top: 18rpx;
}

.ritual-step {
  flex: 1;
  min-width: 0;
  min-height: 142rpx;
  padding: 18rpx;
  text-align: left;
  background: #fbfaf6;
  border: 1rpx solid #dfe5df;
  border-radius: 14rpx;
}

.ritual-step.active {
  background: #e7f1e9;
  border-color: rgba(92, 143, 115, 0.36);
}

.ritual-step.disabled {
  opacity: 0.62;
}

.ritual-order {
  display: block;
  color: #b56d3f;
  font-size: 21rpx;
  font-weight: 800;
}

.ritual-title {
  display: block;
  margin-top: 8rpx;
  color: #17385b;
  font-size: 28rpx;
  font-weight: 800;
}

.ritual-body {
  display: block;
  margin-top: 6rpx;
  color: #7a8584;
  font-size: 22rpx;
  line-height: 1.45;
}

.intention-box {
  margin-top: 18rpx;
}

.field-label.compact {
  margin-top: 0;
}

.intention-input {
  width: 100%;
  min-height: 78rpx;
  padding: 0 20rpx;
  color: #1d2b2c;
  background: #ffffff;
  border: 1rpx solid #dfe5df;
  border-radius: 12rpx;
  font-size: 26rpx;
}

.spark-card {
  margin-top: 18rpx;
  padding: 22rpx;
  background: #fbfaf6;
  border: 1rpx dashed rgba(181, 109, 63, 0.42);
  border-radius: 16rpx;
}

.spark-card.open {
  background: #ffffff;
  border-style: solid;
}

.spark-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.spark-mark {
  display: block;
  color: #b56d3f;
  font-size: 22rpx;
  font-weight: 800;
}

.spark-title {
  display: block;
  margin-top: 6rpx;
  color: #17385b;
  font-size: 30rpx;
  font-weight: 800;
}

.spark-btn {
  flex: 0 0 auto;
  min-width: 112rpx;
  min-height: 60rpx;
  padding: 0 18rpx;
  color: #ffffff;
  background: #17385b;
  border-radius: 10rpx;
  font-size: 24rpx;
  font-weight: 800;
}

.spark-body,
.spark-action {
  display: block;
  margin-top: 14rpx;
  color: #526060;
  font-size: 25rpx;
  line-height: 1.65;
}

.spark-action {
  color: #5c8f73;
  font-weight: 800;
}

.reward-box {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  margin-top: 18rpx;
  padding: 20rpx;
  background: #e7f1e9;
  border: 1rpx solid rgba(92, 143, 115, 0.28);
  border-radius: 16rpx;
}

.reward-summary {
  flex: 1;
  min-width: 0;
}

.reward-title {
  display: block;
  color: #17385b;
  font-size: 29rpx;
  font-weight: 800;
}

.reward-body {
  display: block;
  margin-top: 6rpx;
  color: #526060;
  font-size: 23rpx;
  line-height: 1.45;
}

.reward-badges {
  display: flex;
  flex-wrap: wrap;
  justify-content: flex-end;
  gap: 8rpx;
  width: 310rpx;
}

.reward-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 46rpx;
  padding: 0 14rpx;
  color: #7a8584;
  background: rgba(255, 255, 255, 0.62);
  border: 1rpx solid rgba(122, 133, 132, 0.22);
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 800;
}

.reward-badge.earned {
  color: #5c8f73;
  background: #ffffff;
  border-color: rgba(92, 143, 115, 0.34);
}

.tomorrow-preview {
  margin-top: 18rpx;
  padding: 20rpx;
  background: #ffffff;
  border: 1rpx solid #dfe5df;
  border-radius: 16rpx;
}

.preview-label {
  display: block;
  color: #5c8f73;
  font-size: 23rpx;
  font-weight: 800;
}

.preview-title {
  display: block;
  margin-top: 8rpx;
  color: #17385b;
  font-size: 29rpx;
  font-weight: 800;
}

.preview-body {
  display: block;
  margin-top: 8rpx;
  color: #526060;
  font-size: 25rpx;
  line-height: 1.6;
}

.section-head.compact {
  margin-bottom: 14rpx;
}

.date-picker {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 78rpx;
  padding: 0 20rpx;
  color: #17385b;
  background: #fbfaf6;
  border: 1rpx solid #dfe5df;
  border-radius: 12rpx;
  font-size: 26rpx;
  font-weight: 800;
}

.helper-text {
  display: block;
  margin-top: 12rpx;
  color: #7a8584;
  font-size: 23rpx;
  line-height: 1.55;
}

.metric-card {
  flex: 1;
  min-width: 0;
  padding: 22rpx;
  background: #ffffff;
  border: 1rpx solid #dfe5df;
  border-radius: 16rpx;
}

.metric-label {
  display: block;
  color: #7a8584;
  font-size: 22rpx;
}

.metric-value {
  display: block;
  margin-top: 10rpx;
  color: #17385b;
  font-size: 40rpx;
  font-weight: 800;
}

.day-grid {
  font-size: 0;
}

.day-cell {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 60rpx;
  height: 60rpx;
  min-width: 0;
  margin: 0 10rpx 10rpx 0;
  color: #526060;
  background: #fbfaf6;
  border: 1rpx solid #dfe5df;
  border-radius: 10rpx;
  font-size: 24rpx;
  font-weight: 700;
  vertical-align: top;
}

.day-cell.active {
  color: #ffffff;
  background: #17385b;
}

.day-title {
  display: block;
  margin: 16rpx 0 10rpx;
  color: #17385b;
  font-size: 34rpx;
  font-weight: 800;
  line-height: 1.3;
}

.slider-row {
  margin-top: 20rpx;
  color: #526060;
  font-size: 26rpx;
}

.task-list {
  margin-top: 18rpx;
}

.task-row {
  display: flex;
  gap: 14rpx;
  width: 100%;
  padding: 20rpx;
  margin-bottom: 12rpx;
  color: #526060;
  text-align: left;
  background: #fbfaf6;
  border: 1rpx solid #dfe5df;
  border-radius: 12rpx;
  font-size: 26rpx;
}

.task-row.done {
  color: #5c8f73;
  background: #e7f1e9;
}

.field-label {
  display: block;
  margin: 20rpx 0 10rpx;
  color: #17385b;
  font-size: 26rpx;
  font-weight: 800;
}

.complete-btn {
  margin-top: 22rpx;
}

.sleep-hero {
  padding: 22rpx;
  background: #e8eef4;
  border: 1rpx solid rgba(23, 56, 91, 0.16);
  border-radius: 14rpx;
}

.sleep-title {
  display: block;
  color: #17385b;
  font-size: 32rpx;
  font-weight: 800;
  line-height: 1.35;
}

.sleep-feedback {
  display: block;
  margin-top: 10rpx;
  color: #526060;
  font-size: 25rpx;
  line-height: 1.55;
}

.sleep-list,
.homework-list,
.kitchen-list {
  margin-top: 18rpx;
}

.sleep-item {
  padding: 20rpx;
  margin-bottom: 14rpx;
  background: #fbfaf6;
  border: 1rpx solid #dfe5df;
  border-radius: 14rpx;
}

.sleep-item-head {
  display: flex;
  justify-content: space-between;
  gap: 18rpx;
  color: #17385b;
  font-size: 27rpx;
  font-weight: 800;
}

.sleep-item-body {
  display: block;
  margin-top: 8rpx;
  color: #526060;
  font-size: 24rpx;
  line-height: 1.5;
}

.score-options {
  display: flex;
  gap: 10rpx;
  margin-top: 14rpx;
}

.score-option {
  flex: 1;
  min-height: 62rpx;
  color: #526060;
  background: #ffffff;
  border: 1rpx solid #dfe5df;
  border-radius: 10rpx;
  font-size: 24rpx;
  font-weight: 800;
}

.score-option.active {
  color: #ffffff;
  background: #17385b;
  border-color: #17385b;
}

.homework-field {
  margin-top: 14rpx;
}

.field-label.compact {
  margin-top: 0;
}

.textarea.small {
  min-height: 116rpx;
}

.kitchen-thesis {
  display: block;
  margin-bottom: 12rpx;
  color: #17385b;
  font-size: 32rpx;
  font-weight: 800;
  line-height: 1.35;
}

.kitchen-row {
  display: flex;
  gap: 14rpx;
  width: 100%;
  padding: 20rpx;
  margin-bottom: 12rpx;
  color: #526060;
  text-align: left;
  background: #ffffff;
  border: 1rpx solid #dfe5df;
  border-radius: 12rpx;
  font-size: 25rpx;
  line-height: 1.45;
}

.kitchen-row.done {
  color: #5c8f73;
  background: #e7f1e9;
  border-color: rgba(92, 143, 115, 0.32);
}

@media (max-width: 380px) {
  .engagement-hero,
  .reward-box {
    flex-direction: column;
    align-items: stretch;
  }

  .engagement-ring,
  .reward-badges {
    width: 100%;
  }

  .reward-badges {
    justify-content: flex-start;
  }
}
