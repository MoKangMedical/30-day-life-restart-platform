.tabs {
  display: flex;
  gap: 14rpx;
  margin-bottom: 18rpx;
}

.tab {
  flex: 1;
  min-height: 72rpx;
  color: #4f5c5b;
  background: #f6f8f6;
  border: 1rpx solid #e4e9e4;
  border-radius: 12rpx;
  font-size: 26rpx;
  font-weight: 700;
}

.tab.active {
  color: #17324f;
  background: #eef3f7;
}

.field {
  padding: 20rpx;
  margin-bottom: 16rpx;
  background: #f6f8f6;
  border: 1rpx solid #e4e9e4;
  border-radius: 12rpx;
}

.field-title {
  display: block;
  color: #17324f;
  font-size: 28rpx;
  font-weight: 800;
}

.field-helper {
  display: block;
  margin: 8rpx 0 14rpx;
  color: #879190;
  font-size: 24rpx;
  line-height: 1.5;
}

.copy-btn {
  min-width: 110rpx;
  min-height: 58rpx;
  color: #17324f;
  background: #eef3f7;
  border-radius: 10rpx;
  font-size: 24rpx;
  font-weight: 800;
}

.generated {
  min-height: 420rpx;
}
