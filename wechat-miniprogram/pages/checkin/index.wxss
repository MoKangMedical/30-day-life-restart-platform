.tabs {
  display: flex;
  gap: 14rpx;
  margin-bottom: 18rpx;
}

.tab {
  flex: 1;
  min-height: 72rpx;
  color: #526060;
  background: #fbfaf6;
  border: 1rpx solid #dfe5df;
  border-radius: 12rpx;
  font-size: 26rpx;
  font-weight: 700;
}

.tab.active {
  color: #17385b;
  background: #e8eef4;
}

.field {
  padding: 20rpx;
  margin-bottom: 16rpx;
  background: #fbfaf6;
  border: 1rpx solid #dfe5df;
  border-radius: 12rpx;
}

.field-title {
  display: block;
  color: #17385b;
  font-size: 28rpx;
  font-weight: 800;
}

.field-helper {
  display: block;
  margin: 8rpx 0 14rpx;
  color: #7a8584;
  font-size: 24rpx;
  line-height: 1.5;
}

.copy-btn {
  min-width: 110rpx;
  min-height: 58rpx;
  color: #17385b;
  background: #e8eef4;
  border-radius: 10rpx;
  font-size: 24rpx;
  font-weight: 800;
}

.generated {
  min-height: 420rpx;
}
