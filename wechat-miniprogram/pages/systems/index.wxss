.system-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.system-card {
  width: calc(50% - 8rpx);
  min-height: 160rpx;
  padding: 20rpx;
  text-align: left;
  background: #f6f8f6;
  border: 1rpx solid #e4e9e4;
  border-radius: 14rpx;
}

.system-card.active {
  background: #eef3f7;
  border-color: #d7e1ea;
}

.system-order {
  display: block;
  color: #a35f36;
  font-size: 22rpx;
  font-weight: 800;
}

.system-name {
  display: block;
  margin-top: 10rpx;
  color: #17324f;
  font-size: 30rpx;
  font-weight: 800;
}

.system-duration {
  display: block;
  margin-top: 12rpx;
  color: #4f8065;
  font-size: 23rpx;
}

.meta-row {
  display: flex;
  gap: 12rpx;
  margin-bottom: 18rpx;
}

.detail-label {
  display: block;
  margin: 22rpx 0 8rpx;
  color: #17324f;
  font-size: 27rpx;
  font-weight: 800;
}

.training-list {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.training-item {
  color: #4f5c5b;
  font-size: 26rpx;
  line-height: 1.6;
}
