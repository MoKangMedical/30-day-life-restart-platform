page {
  min-height: 100vh;
  color: #172526;
  background: #f8faf8;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Microsoft YaHei", sans-serif;
}

view,
text,
button,
textarea,
input,
slider {
  box-sizing: border-box;
}

button {
  padding: 0;
  margin: 0;
  line-height: 1.4;
  background: transparent;
}

button::after {
  border: 0;
}

.page {
  padding: 28rpx;
}

.hero {
  padding: 30rpx;
  color: #172526;
  background: #ffffff;
  border: 1rpx solid #e4e9e4;
  border-radius: 14rpx;
}

.hero-title {
  display: block;
  color: #17324f;
  font-size: 44rpx;
  font-weight: 800;
  line-height: 1.2;
}

.hero-subtitle {
  display: block;
  margin-top: 14rpx;
  color: #4f5c5b;
  font-size: 26rpx;
  line-height: 1.55;
}

.panel {
  padding: 26rpx;
  margin-top: 22rpx;
  background: #ffffff;
  border: 1rpx solid #e4e9e4;
  border-radius: 14rpx;
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-bottom: 18rpx;
  margin-bottom: 20rpx;
  border-bottom: 1rpx solid #e4e9e4;
}

.section-title {
  color: #17324f;
  font-size: 32rpx;
  font-weight: 800;
}

.section-action {
  color: #879190;
  font-size: 24rpx;
}

.muted {
  color: #4f5c5b;
  font-size: 26rpx;
  line-height: 1.65;
}

.tag {
  display: inline-flex;
  padding: 8rpx 14rpx;
  color: #4f8065;
  background: #edf5ef;
  border-radius: 10rpx;
  font-size: 22rpx;
  font-weight: 700;
}

.primary-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 82rpx;
  padding: 0 24rpx;
  color: #ffffff;
  background: #17324f;
  border-radius: 10rpx;
  font-size: 28rpx;
  font-weight: 800;
}

.ghost-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 74rpx;
  padding: 0 22rpx;
  color: #17324f;
  background: #eef3f7;
  border: 1rpx solid #e4e9e4;
  border-radius: 10rpx;
  font-size: 26rpx;
  font-weight: 700;
}

.textarea {
  width: 100%;
  min-height: 150rpx;
  padding: 20rpx;
  color: #172526;
  background: #f6f8f6;
  border: 1rpx solid #e4e9e4;
  border-radius: 10rpx;
  font-size: 26rpx;
  line-height: 1.6;
}

.nav-grid {
  font-size: 0;
}

.nav-card {
  display: inline-block;
  width: calc(50% - 9rpx);
  min-height: 138rpx;
  padding: 22rpx;
  margin: 0 18rpx 18rpx 0;
  text-align: left;
  background: #ffffff;
  border: 1rpx solid #e4e9e4;
  border-radius: 10rpx;
  vertical-align: top;
}

.nav-card:nth-child(2n) {
  margin-right: 0;
}

.nav-card-title {
  display: block;
  color: #17324f;
  font-size: 29rpx;
  font-weight: 800;
}

.nav-card-body {
  display: block;
  margin-top: 10rpx;
  color: #4f5c5b;
  font-size: 23rpx;
  line-height: 1.45;
}
